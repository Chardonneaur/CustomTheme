# Block all direct HTTP access to uploaded font files.
# Assets are served exclusively through the PHP proxy
# (index.php?module=CustomTheme&action=serveFont).
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
